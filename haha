class Solution {
public://012
    void sortColors(vector<int>& nums) {
        // int startfor1=0;
        // for (int i = 0; i < nums.size(); i++)
        // {
        //     if (nums[i]!=0)
        //     {int j=i+1;
        //         while (nums[j]!=0 && j != nums.size())
        //         {j++;
        //             /* code */
        //         }
        //         if (nums[i]!=0 && nums[j]==0)
        //         {swap(nums[i],nums[j]);
        //             startfor1=i+1;
        //             /* code */
        //         }
                
        //         /* code */
        //     }
        // }

        //      for (int i = startfor1; i < nums.size(); i++)
        // {
        //     if (nums[i]!=1)
        //     {int j=i+1;
        //         while (nums[j]!=1 && j != nums.size())
        //         {j++;
        //             /* code */
        //         }
        //         if (nums[i]!=1 && nums[j]==1)
        //         {swap(nums[i],nums[j]);
        //             /* code */
        //         }
                
        //         /* code */
        //     }
            
        //     /* code */
        // }
        
        //::using Dutch national flag algo

        int low=0,mid=0,high=nums.size()-1;
        while(mid<=high)//once mid crosses high it means we have got into range of 2 hence end sorting
                //our partitions look like this: 0th index--->low : 0
                                            //   low+1--->mid : 1
                                            //      mid+1-->high:unsorted
                                            //high--->end : 2
        {
            if (nums[mid]==0)
            {swap(nums[low],nums[mid]);
                low++;mid++;
                //why mid++ why theres need to do mid++, as if theres an (previously at low)element which got swapped with mid now mids value changed now isnt there need to check if mids elemnt need to shifted,btw this is dnf algo
                //becoz:case 1 elemnt at ow is 0 in that case its where it was suppose tobe so mid++
                    //case 2 elmt=1 still mid++makes sense
                    //case 3 elmt=2 never happens aas if 2 was previously encountered it got swapped with high
                /* code */
            }
            else if (nums[mid]==2)
            {swap(nums[high],nums[mid]);
               high--;
                /* code */
            }
            else
            {mid++;
                /* code */
            }
            


        }



    }
};
